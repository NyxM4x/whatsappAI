# ===== Kapso (WhatsApp Cloud API) =====
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== OpenAI (bot de respuestas) =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== Bot control (pause/resume/status) =====
BOT_CONTROL_SECRET=

# ===== Google Calendar (clínica) =====
# JSON completo de la service account (contenido del archivo .json descargado de Google Cloud).
GOOGLE_SERVICE_ACCOUNT_JSON=

# ===== Clínica — crons =====
# CRON_SECRET: Vercel la inyecta automáticamente como Bearer token en los cron
# jobs (debe llamarse exactamente así). Protege /api/cron/clinic-reminders y
# /api/cron/clinic-confirmations.
CRON_SECRET=
# Alternativas dedicadas (opcionales, no hace falta configurarlas si ya está CRON_SECRET):
CLINIC_REMIND_CRON_SECRET=
CLINIC_CONFIRM_CRON_SECRET=

# ===== Panel interno (/admin) — secretaria =====
# Firma las cookies de sesión del login. Generar con algo como:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# ===== Alertas / utilidades opcionales =====
SLACK_ALERT_WEBHOOK_URL=
# Restringe el webhook a un solo número para pruebas (solo dígitos).
TEST_PHONE=

# ===== Follow-up automático (cron /api/cron/followups) =====
# Secreto que protege el endpoint cron (header Authorization: Bearer <secreto>).
FOLLOWUP_CRON_SECRET=
# Dry-run por defecto: cualquier valor distinto de 'false' = no envía ni inserta filas.
FOLLOWUP_DRY_RUN=true
# Máximo de envíos reales por corrida del cron.
FOLLOWUP_SEND_LIMIT=5
# Máximo de envíos reales por día (día calendario, hora de Bolivia).
FOLLOWUP_DAILY_LIMIT=30
# (Opcional) Limita detección y envío a una sola conversación, para pruebas.
FOLLOWUP_TEST_CONVERSATION_ID=
# (Opcional) Override del retardo 6-8h por minutos, para pruebas end-to-end aceleradas.
FOLLOWUP_DELAY_MINUTES_MIN=
FOLLOWUP_DELAY_MINUTES_MAX=
